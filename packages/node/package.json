{
  "name": "@appss/sdk-node",
  "version": "0.3.1",
  "description": "APPSS analytics SDK for Node.js (Telegram bots, servers)",
  "keywords": [
    "analytics",
    "sdk",
    "tracking",
    "telegram",
    "node",
    "bot"
  ],
  "type": "module",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/engagementlabs/appss-sdk-js.git",
    "directory": "packages/node"
  },
  "publishConfig": {
    "access": "public"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist .turbo coverage"
  },
  "dependencies": {
    "@appss/sdk-core": "0.4.1"
  }
}
